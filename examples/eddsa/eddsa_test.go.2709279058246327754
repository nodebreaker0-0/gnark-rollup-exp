package eddsa

import (
	"math/big"
	"math/rand"
	"testing"

	tedwards "github.com/consensys/gnark-crypto/ecc/twistededwards"
	"github.com/consensys/gnark-crypto/hash"
	ceddsa "github.com/consensys/gnark-crypto/signature/eddsa"
	"github.com/consensys/gnark-crypto/ecc"
	"github.com/consensys/gnark/test"
	"github.com/nodebreaker0-0/gnark-rollup-exp/prove"
)

// signFixture deterministically generates a key, signs a message, and returns an
// assignment plus the raw bytes needed to build invalid variants.
func signFixture(t *testing.T) (msg big.Int, pubBytes, sig []byte) {
	t.Helper()
	field := ecc.BN254.ScalarField()
	r := rand.New(rand.NewSource(1)) //#nosec G404 -- deterministic test fixture

	priv, err := ceddsa.New(tedwards.BN254, r)
	if err != nil {
		t.Fatalf("generate key: %v", err)
	}

	msg.Rand(r, field)
	unpadded := msg.Bytes()
	msgData := make([]byte, len(field.Bytes()))
	copy(msgData[len(msgData)-len(unpadded):], unpadded)

	sig, err = priv.Sign(msgData, hash.MIMC_BN254.New())
	if err != nil {
		t.Fatalf("sign: %v", err)
	}
	return msg, priv.Public().Bytes(), sig
}

func TestProveVerify(t *testing.T) {
	msg, pubBytes, sig := signFixture(t)

	w := New()
	w.Message = msg
	w.PublicKey.Assign(tedwards.BN254, pubBytes)
	w.Signature.Assign(tedwards.BN254, sig)

	if err := prove.Run(New(), w); err != nil {
		t.Fatalf("expected proof to verify: %v", err)
	}
}

func TestConstraints(t *testing.T) {
	field := ecc.BN254.ScalarField()
	msg, pubBytes, sig := signFixture(t)

	valid := New()
	valid.Message = msg
	valid.PublicKey.Assign(tedwards.BN254, pubBytes)
	valid.Signature.Assign(tedwards.BN254, sig)
	if err := test.IsSolved(New(), valid, field); err != nil {
		t.Fatalf("valid signature should solve: %v", err)
	}

	// Wrong message under the same signature must fail.
	bad := New()
	var other big.Int
	other.Add(&msg, big.NewInt(1))
	bad.Message = other
	bad.PublicKey.Assign(tedwards.BN254, pubBytes)
	bad.Signature.Assign(tedwards.BN254, sig)
	if err := test.IsSolved(New(), bad, field); err == nil {
		t.Fatal("signature over a different message should not solve, but it did")
	}
}
